{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["spotifysdk"],
  "ios": {
    "iosModuleName": "NitroSpotifySdk"
  },
  "android": {
    "androidNamespace": ["spotifysdk"],
    "androidCxxLibName": "NitroSpotifySdk"
  },
  "autolinking": {
    "SpotifyPlayer": {
      "swift": "SpotifyPlayer",
      "kotlin": "SpotifyPlayer"
    },
    "SpotifyAuth": {
      "swift": "SpotifyAuth",
      "kotlin": "SpotifyAuth"
    }
  },
  "ignorePaths": ["**/node_modules"]
}
